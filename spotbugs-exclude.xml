<FindBugsFilter>
    <!-- EI_EXPOSE_REP on GeneratorContext.random() is intentional and suppressed. -->
    <Match>
        <Class name="se.plilja.jsonschemagen.internal.generator.GeneratorContext"/>
        <Method name="random"/>
        <Bug pattern="EI_EXPOSE_REP"/>
    </Match>
    <!-- Schema is sealed and effectively immutable: fields are set only during
         Jackson deserialization (via @JsonSetter with List.copyOf) or Lombok
         builder construction (internal code, always passes safe lists). -->
    <Match>
        <Class name="se.plilja.jsonschemagen.internal.model.SchemaDocument"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <!-- Conditional is a plain record over Schema references; same
         effectively-immutable rationale as above, but records don't get
         Lombok's @lombok.Generated pass on their accessors. -->
    <Match>
        <Class name="se.plilja.jsonschemagen.internal.model.Schema$Conditional"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
    <!-- StringFormatGenerator is abstract and package-private; all subclasses are final.
         No finalizer attack surface exists. -->
    <Match>
        <Class name="se.plilja.jsonschemagen.internal.generator.format.StringFormatGenerator"/>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>
</FindBugsFilter>
