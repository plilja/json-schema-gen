{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "street": {
      "type": "string",
      "maxLength": 200
    },
    "city": {
      "type": "string",
      "maxLength": 100
    },
    "state": {
      "type": "string",
      "maxLength": 100
    },
    "zipCode": {
      "type": "string",
      "pattern": "\\d{5}(-\\d{4})?"
    },
    "country": {
      "type": "string",
      "minLength": 2,
      "maxLength": 2
    }
  },
  "required": [
    "zipCode",
    "country"
  ],
  "additionalProperties": false
}
