{
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "format": "int64"
        },
        "status": {
            "type": "string",
            "enum": [
                "PENDING",
                "CONFIRMED",
                "SHIPPED",
                "DELIVERED",
                "CANCELLED"
            ]
        },
        "items": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/OrderItem"
            },
            "maxItems": 100,
            "minItems": 0
        },
        "shippingAddress": {
            "$ref": "#/definitions/Address"
        },
        "billingAddress": {
            "$ref": "#/definitions/Address"
        },
        "createdAt": {
            "type": "string",
            "format": "date-time"
        },
        "updatedAt": {
            "type": "string",
            "format": "date-time"
        }
    },
    "required": [
        "items",
        "shippingAddress",
        "status"
    ],
    "definitions": {
        "Address": {
            "type": "object",
            "properties": {
                "street": {
                    "type": "string",
                    "maxLength": 200,
                    "minLength": 0
                },
                "city": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 0
                },
                "state": {
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 0
                },
                "zipCode": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "\\d{5}(-\\d{4})?"
                },
                "country": {
                    "type": "string",
                    "maxLength": 2,
                    "minLength": 2
                }
            },
            "required": [
                "city",
                "country",
                "street",
                "zipCode"
            ]
        },
        "OrderItem": {
            "type": "object",
            "properties": {
                "productName": {
                    "type": "string",
                    "minLength": 1
                },
                "quantity": {
                    "type": "integer",
                    "format": "int32",
                    "minimum": 1
                },
                "unitPrice": {
                    "type": "number",
                    "minimum": 0.01
                }
            },
            "required": [
                "productName",
                "unitPrice"
            ]
        }
    }
}
